{
  "name": "ripple-st-client",
  "description": "WebSocket client for the Ripple event bus protocol",
  "version": "0.2.1",
  "author": "Masashi Umezawa",
  "bugs": {
    "url": "https://github.com/mumez/ripple-st-client/issues"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "eslint": "^9.0.0",
    "rollup": "^4.0.0",
    "vitest": "^4.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "homepage": "https://github.com/mumez/ripple-st-client#readme",
  "keywords": [
    "event-bus",
    "pubsub",
    "ripple",
    "websocket"
  ],
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/mumez/ripple-st-client.git"
  },
  "scripts": {
    "build": "rollup -c && cp src/index.d.ts dist/index.d.ts",
    "lint": "eslint src",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
